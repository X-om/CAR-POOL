    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3"
  },
  "dependencies": {
    "@repo/kafka": "workspace:*",
    "handlebars": "^4.7.8",
    "kafkajs": "^2.2.4",
    "zod": "^4.3.6"
  }
}
