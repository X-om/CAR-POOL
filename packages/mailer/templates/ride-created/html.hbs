<div style="font-family: Arial, sans-serif; line-height: 1.5;">
  <h2>Ride published</h2>
  <p>Your ride has been created.</p>
  <ul>
    <li><strong>Ride ID:</strong> {{rideId}}</li>
    {{#if sourceCity}}<li><strong>From:</strong> {{sourceCity}}</li>{{/if}}
    {{#if destinationCity}}<li><strong>To:</strong> {{destinationCity}}</li>{{/if}}
    {{#if departureTime}}<li><strong>Departure:</strong> {{departureTime}}</li>{{/if}}
  </ul>
</div>
