# Frontend environment variables (Next.js)
#
# Copy this file to:
#   apps/web/.env.local
#

# REST API Gateway (apps/api-gateway)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3000

# WebSocket Gateway (apps/webSocket-gateway)
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:3001

# Mapbox public access token (optional, required for map-based flows)
# Get from Mapbox: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Firebase (optional; only needed if you enable Firebase phone auth)
# Get from Firebase Console → Project settings → Your apps → Web app config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
