# Backend environment variables (services + workers)
#
# Copy to one of these (repo root) depending on your preference:
#   - .env.local   (recommended)
#   - env.local
#   - .env
#
# Notes
# - Values below are set up for running Node services locally while Postgres/Redis/Redpanda run in Docker.
# - If you run the full backend stack in Docker Compose (`infra/docker/docker-compose.yml --profile app up -d`),
#   Docker already supplies defaults, and you may not need a local env file.
#

# -----------------------------------------------------------------------------
# Core infrastructure (required)
# -----------------------------------------------------------------------------

# Postgres (running on your host via Docker port mapping)
DATABASE_URL=postgres://carpool:carpool@127.0.0.1:5432/carpool

# Redis (running on your host via Docker port mapping)
REDIS_URL=redis://127.0.0.1:6379

# Kafka / Redpanda
# IMPORTANT: use Redpanda's "OUTSIDE" listener for host-based clients.
KAFKA_BROKERS=127.0.0.1:19092

# -----------------------------------------------------------------------------
# Auth + internal service auth
# -----------------------------------------------------------------------------

# App JWT signing secret (used by user-service, api-gateway, webSocket-gateway)
# Change this in real deployments.
JWT_SECRET=dev-jwt-secret-32chars-minimum!!

# Internal service-to-service auth secret (used for gRPC internal auth)
# Change this in real deployments.
INTERNAL_JWT_SECRET=dev-internal-jwt-secret-32chars!!

# Shared email/app branding
APP_NAME=RideLink
MAIL_FROM=no-reply@ridelink.local

# -----------------------------------------------------------------------------
# API Gateway (apps/api-gateway)
# -----------------------------------------------------------------------------

BACKEND_PORT=3000

# gRPC downstream addresses (when running services locally)
USER_SERVICE_GRPC_ADDR=127.0.0.1:50051
VEHICLE_SERVICE_GRPC_ADDR=127.0.0.1:50052
RIDE_SERVICE_GRPC_ADDR=127.0.0.1:50053
SEARCH_SERVICE_GRPC_ADDR=127.0.0.1:50054
BOOKING_SERVICE_GRPC_ADDR=127.0.0.1:50055
TRIP_SERVICE_GRPC_ADDR=127.0.0.1:50056
NOTIFICATION_SERVICE_GRPC_ADDR=127.0.0.1:50057

# Search behavior (apps/search-service)
# How far (km) a searched origin/destination can be from any ride stop.
# Increase to match across nearby neighborhoods.
SEARCH_RADIUS_KM=10

# -----------------------------------------------------------------------------
# gRPC service ports (when running services locally)
# -----------------------------------------------------------------------------

USER_SERVICE_GRPC_PORT=50051
VEHICLE_SERVICE_GRPC_PORT=50052
RIDE_SERVICE_GRPC_PORT=50053
SEARCH_SERVICE_GRPC_PORT=50054
BOOKING_SERVICE_GRPC_PORT=50055
TRIP_SERVICE_GRPC_PORT=50056
NOTIFICATION_SERVICE_GRPC_PORT=50057

# -----------------------------------------------------------------------------
# WebSocket Gateway (apps/webSocket-gateway)
# -----------------------------------------------------------------------------

WS_PORT=3001

# -----------------------------------------------------------------------------
# User service (apps/user-service)
# -----------------------------------------------------------------------------

OTP_EXPIRY_MINUTES=10

# Firebase phone auth support
# - Keep disabled for local dev unless you want real Firebase verification.
# - If enabled, you must provide FIREBASE_SERVICE_ACCOUNT_JSON.
FIREBASE_AUTH_ENABLED=false

# Only required if FIREBASE_AUTH_ENABLED=true
# Get from Firebase Console → Project settings → Service accounts → "Generate new private key"
# Then paste the JSON *as a single line* below.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# -----------------------------------------------------------------------------
# Notification service + worker (apps/notification-service)
# -----------------------------------------------------------------------------

NOTIFICATION_KAFKA_GROUP_ID=notification-service.v1

# -----------------------------------------------------------------------------
# Outbox publisher (apps/outbox-publisher)
# -----------------------------------------------------------------------------

# Optional: Kafka clientId used by outbox publisher and some producers.
# KAFKA_CLIENT_ID=outbox-publisher

OUTBOX_SCHEMAS=user_service,vehicle_service,ride_service,search_service,booking_service,trip_service,notification_service
OUTBOX_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=100

# -----------------------------------------------------------------------------
# Reminder worker (apps/reminder-worker)
# -----------------------------------------------------------------------------

REMINDER_INTERVAL_MS=60000
REMINDER_LEAD_MINUTES=60
REMINDER_WINDOW_MINUTES=15

# -----------------------------------------------------------------------------
# Mailer worker (apps/mailer-worker)
# -----------------------------------------------------------------------------

MAILER_KAFKA_GROUP_ID=mailer-worker

# For local dev, use Mailpit (from docker compose profile app):
# - SMTP: localhost:1025
# - UI:   http://127.0.0.1:8025

SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false

# If your SMTP server requires auth:
# SMTP_USER=
# SMTP_PASS=
